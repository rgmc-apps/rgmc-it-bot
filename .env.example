# ─── Microsoft Bot / Entra App Registration ───────────────────────────────────
# Azure Portal → App Registrations → Your App → Overview
BOT_ID=your-app-client-id-here

# Azure Portal → App Registrations → Certificates & secrets → Client secrets
BOT_PASSWORD=your-client-secret-value-here

# Single tenant: your directory tenant ID
# Multi-tenant: leave empty or set to "common"
TENANT_ID=your-tenant-id-here

# ─── Supabase (same instance as rgmc-gateway) ─────────────────────────────────
SUPABASE_URL=https://eesrzpgmsrbhjeenfojq.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here

# ─── Webhook security ─────────────────────────────────────────────────────────
# rgmc-gateway sends this key in X-API-Key header when calling /api/notify/*
WEBHOOK_API_KEY=generate-a-long-random-secret-here

# ─── Optional: portal link in notification cards ──────────────────────────────
# Base URL of rgmc-gateway so cards can include a "View Ticket" button
GATEWAY_BASE_URL=https://your-gateway.run.app

# Base URL of this bot — used to serve the RGMC logo inside Adaptive Cards
# Set to your Cloud Run service URL after deploying
BOT_BASE_URL=https://your-bot.run.app

# ─── OpenAI / ChatGPT ─────────────────────────────────────────────────────────
# platform.openai.com → API keys
GPT_API_KEY=gpt-key-goes-here

# Model to use (e.g. gpt-4o, gpt-4-turbo, gpt-3.5-turbo)
GPT_VERSION=gpt-model-name-goes-here

# Max tokens per response
GPT_LIMIT=1000

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3978
